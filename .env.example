# --- General ---
ENV=development
DEBUG=true
DEFAULT_CITY=Коломна

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me
CORS_ORIGINS=*

# --- Database / Redis ---
DATABASE_URL=postgresql+asyncpg://citymind:citymind@localhost:5432/citymind
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# --- External APIs ---
OPENWEATHER_API_KEY=
VK_API_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=citymind
YANDEX_API_KEY=
GOSUSLUGI_API_KEY=

# --- DeepSeek (news enrichment) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
ENRICHMENT_BATCH_SIZE=20
ENRICHMENT_MAX_ITEMS=60
ENRICHMENT_CACHE_TTL_HOURS=24

# --- Collectors ---
COLLECTION_INTERVAL_MIN=30
NEWS_LOOKBACK_HOURS=24

# --- ML ---
SENTIMENT_MODEL=blanchefort/rubert-base-cased-sentiment
